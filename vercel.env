## Vercel-importable environment variables (PUBLIC / NON-SECRET ONLY)
## Safe to import into Vercel via: Project Settings → Environment Variables → Import
##
## DO NOT put secrets in this file.
## Add these separately in Vercel (server-only):
## - SANITY_API_WRITE_TOKEN
## - SANITY_REVALIDATE_TOKEN

SANITY_PROJECT_ID=u5qpmyb0
SANITY_DATASET=production
SANITY_API_VERSION=2026-04-01

# If any client-side code expects these, they must be NEXT_PUBLIC_*
NEXT_PUBLIC_SANITY_PROJECT_ID=u5qpmyb0
NEXT_PUBLIC_SANITY_DATASET=production

# EmailJS (intentionally public; used in the browser)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_eux3aap
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_k9tpceg
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=bnC6xi6v9qB1s8SVe
